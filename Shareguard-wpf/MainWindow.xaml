<ui:FluentWindow x:Class="ShareGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:ShareGuard.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="{Binding Title}"
        Height="650" Width="500"
        MinHeight="500" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <ui:FluentWindow.Resources>
        <!-- Converters for state visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <Grid Margin="0,36,0,0">
        <!-- ═══════════════════════════════════════════════ -->
        <!-- STATE 1: DROP ZONE (visible when CurrentState == DropZone) -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid x:Name="DropZonePanel" Margin="32">
            <Border BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Background="Transparent"
                    Padding="32">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{ui:ThemeResource ControlStrokeColorDefaultBrush}" />
                    </Style>
                </Border.Style>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="ArrowDownload24"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16" />

                    <TextBlock Text="Drag &amp; drop your image here"
                               FontSize="20"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />

                    <TextBlock Text="Supports JPEG, PNG, and WEBP. Original files are never modified."
                               FontSize="13"
                               Opacity="0.6"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,24" />

                    <ui:Button Content="Browse Files"
                               Appearance="Primary"
                               Icon="{ui:SymbolIcon FolderOpen24}"
                               HorizontalAlignment="Center"
                               Padding="24,10"
                               Command="{Binding BrowseFileCommand}" />

                    <!-- Error message (if any) -->
                    <Border x:Name="ErrorBanner"
                             Background="#33C42B1C"
                             CornerRadius="8"
                             Padding="16,10"
                             Margin="0,20,0,0"
                             Visibility="Collapsed">
                        <TextBlock x:Name="ErrorText"
                                   Foreground="#FFC42B1C"
                                   TextWrapping="Wrap"
                                   FontSize="13" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- STATE 2: PROCESSING (visible when CurrentState == Processing) -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid x:Name="ProcessingPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="64" Height="64"
                                 Margin="0,0,0,24" />

                <TextBlock Text="Cleaning image metadata..."
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <TextBlock Text="Stripping GPS, camera, date, and software data"
                           FontSize="13"
                           Opacity="0.6"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- STATE 3: RESULTS (visible when CurrentState == Results) -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid x:Name="ResultsPanel" Visibility="Collapsed" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Success banner -->
            <Border Grid.Row="0"
                    Background="#3300A86B"
                    CornerRadius="10"
                    Padding="16"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                   Foreground="#FF00A86B"
                                   FontSize="28"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Image cleaned successfully"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="ElapsedText"
                                   FontSize="12"
                                   Opacity="0.6"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- File paths card -->
            <ui:Card Grid.Row="1" Margin="0,0,0,16" Padding="16">
                <StackPanel>
                    <TextBlock Text="Original"
                               FontSize="11"
                               Opacity="0.5"
                               Margin="0,0,0,2" />
                    <TextBlock x:Name="OriginalPathText"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,12" />

                    <TextBlock Text="Clean copy"
                               FontSize="11"
                               Opacity="0.5"
                               Margin="0,0,0,2" />
                    <TextBlock x:Name="CleanPathText"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,12" />

                    <ui:Button Content="Open Folder"
                               Appearance="Primary"
                               Icon="{ui:SymbolIcon FolderOpen24}"
                               HorizontalAlignment="Left"
                               Padding="16,8"
                               Command="{Binding OpenFolderCommand}" />
                </StackPanel>
            </ui:Card>

            <!-- Findings grouped by category -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="FindingsContainer"
                               ItemsSource="{Binding FindingGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:CardExpander Header="{Binding DisplayHeader}"
                                              Margin="0,0,0,8"
                                              IsExpanded="False">
                                <ItemsControl ItemsSource="{Binding Items}" Margin="8,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding FieldName}"
                                                           FontSize="12"
                                                           Opacity="0.7" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           Opacity="0.5" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ui:CardExpander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Back button -->
            <ui:Button Grid.Row="3"
                       Content="Clean Another Image"
                       Icon="{ui:SymbolIcon ArrowLeft24}"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"
                       Padding="24,10"
                       Command="{Binding GoBackCommand}" />
        </Grid>
    </Grid>
</ui:FluentWindow>
